FROM joomla:5.4-php8.2-apache

RUN apt-get update -qq && apt-get install -y --no-install-recommends \
    unzip curl default-mysql-client \
    && rm -rf /var/lib/apt/lists/*

RUN echo "[client]\nskip-ssl" > /etc/mysql/conf.d/no-ssl.cnf

ARG J2C4_URL=https://github.com/j2commerce/j2cart/releases/download/v4.1.3/com_j2store_v4-4.1.3-pro.zip
RUN curl -fsSL "$J2C4_URL" -o /tmp/j2commerce.zip

COPY extension.zip /tmp/extension.zip
COPY scripts/ /scripts/
COPY docker-entrypoint-j2c-base.sh /usr/local/bin/docker-entrypoint-j2c-base.sh
COPY scripts/docker-entrypoint-j2c4.sh /usr/local/bin/custom-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint-j2c-base.sh \
              /usr/local/bin/custom-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/custom-entrypoint.sh"]
CMD ["apache2-foreground"]
