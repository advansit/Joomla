<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="osmap" method="upgrade">
    <name>PLG_OSMAP_J2COMMERCE</name>
    <element>j2commerce</element>
    <author>Advans IT Solutions GmbH</author>
    <creationDate>2026-04</creationDate>
    <copyright>Copyright (C) 2026 Advans IT Solutions GmbH. All rights reserved.</copyright>
    <license>GNU GPL v3</license>
    <authorEmail>info@advans.ch</authorEmail>
    <authorUrl>https://advans.ch</authorUrl>
    <version>1.3.2</version>
    <description>PLG_OSMAP_J2COMMERCE_XML_DESCRIPTION</description>

    <targetplatform name="joomla" version="(5\.[0-9]|6\.[0-9])" />

    <scriptfile>script.php</scriptfile>

    <namespace path="src">Advans\Plugin\Osmap\J2Commerce</namespace>
    <autoloadLanguage>true</autoloadLanguage>

    <files>
        <filename plugin="j2commerce">j2commerce.php</filename>
        <folder>services</folder>
        <folder>src</folder>
        <folder>language</folder>
    </files>

    <config>
        <fields name="params">
            <fieldset name="basic">
                <field
                    name="priority"
                    type="list"
                    default="0.8"
                    label="PLG_OSMAP_PRIORITY_LABEL"
                    description="PLG_OSMAP_PRIORITY_DESC">
                    <option value="0.0">0.0</option>
                    <option value="0.1">0.1</option>
                    <option value="0.2">0.2</option>
                    <option value="0.3">0.3</option>
                    <option value="0.4">0.4</option>
                    <option value="0.5">0.5</option>
                    <option value="0.6">0.6</option>
                    <option value="0.7">0.7</option>
                    <option value="0.8">0.8</option>
                    <option value="0.9">0.9</option>
                    <option value="1.0">1.0</option>
                </field>
                <field
                    name="changefreq"
                    type="list"
                    default="weekly"
                    label="PLG_OSMAP_CHANGEFREQ_LABEL"
                    description="PLG_OSMAP_CHANGEFREQ_DESC">
                    <option value="always">always</option>
                    <option value="hourly">hourly</option>
                    <option value="daily">daily</option>
                    <option value="weekly">weekly</option>
                    <option value="monthly">monthly</option>
                    <option value="yearly">yearly</option>
                    <option value="never">never</option>
                </field>
            </fieldset>
        </fields>
    </config>

    <updateservers>
        <server type="extension" priority="1" name="OSMap J2Commerce">
            https://raw.githubusercontent.com/advansit/Joomla/main/j2commerce/plg_osmap_j2commerce/updates/update.xml
        </server>
    </updateservers>
</extension>
